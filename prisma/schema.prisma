generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }
model User {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  username  String
  password  String
  createdAt DateTime  @default(now())
  isVerified Boolean   @default(false)
  orders    Order[]
  token     Token?
}

model Token {
  id           String @id @default(uuid())
  refreshToken String
  userId       Int    @unique
  user         User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   Int         @unique
  timestamp     DateTime
  userName      String
  userPhone     String
  userAddress   String
  paymentType   String?
  orderType     String?
  cardNumber    String?
  cardExpiry    String?
  cardCvv       String?
  cardHolder    String?
  metadata      Json?
  totalPrice    Float
  totalWeight   Float
  totalDiscount Float
  totalQuantity Int
  status        OrderStatus @default(PENDING)
  cart          OrderItem[]
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id])
  userId        Int
}

model OrderItem {
  id               Int     @id @default(autoincrement())
  order            Order   @relation(fields: [orderId], references: [id])
  orderId          String
  productId        String
  name             String
  quantity         Int
  price            Float
  totalPrice       Float
  weight           Float
  totalWeight      Float
  selectedMaterial String?
  selectedSize     String?
  selectedColor    String?
  discountedPrice  Float?
  discount         Int?
  profit           Float?
}

model Review {
  id         Int      @id @default(autoincrement())
  product    Product  @relation(fields: [productId], references: [id])
  productId  String
  username   String
  rating     Int
  comment    String
  createdAt  DateTime @default(now())
}

model Brand {
  id          String    @id
  name        String
  url         String?
  description String?
  products    Product[]
}

model Category {
  id       String    @id
  name     String
  url      String
  products Product[]
}

model Gender {
  id       String    @id
  name     String
  url      String
  products Product[]
}

model Product {
  id              String    @id
  name            String
  description     String
  image           String?   @default("")
  colorImages     Json      @default("{}")
  price           Float
  weight          Float
  sizes           String[]
  materials       String[]
  colors          String[]
  discountPercent Int?
  discountedPrice Float?
  category        Category  @relation(fields: [categoryId], references: [id])
  categoryId      String
  brand           Brand     @relation(fields: [brandId], references: [id])
  brandId         String
  gender          Gender    @relation(fields: [genderId], references: [id])
  genderId        String
  reviews         Review[]
}
